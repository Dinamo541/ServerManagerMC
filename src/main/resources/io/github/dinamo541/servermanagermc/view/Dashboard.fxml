<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.FlowPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<ScrollPane fitToWidth="true" hbarPolicy="NEVER" styleClass="content-scroll" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="io.github.dinamo541.servermanagermc.controller.DashboardController">
    <VBox spacing="18.0" styleClass="content">
        <padding>
            <Insets bottom="24.0" left="24.0" right="24.0" top="22.0" />
        </padding>

        <Label styleClass="title" text="Dashboard" />

        <!-- Hero de estado -->
        <HBox alignment="CENTER_LEFT" spacing="14.0" styleClass="state-hero">
            <Label fx:id="stateDot" styleClass="state-dot" text="●" />
            <VBox spacing="2.0">
                <Label fx:id="stateLabel" styleClass="state-text" text="—" />
                <Label styleClass="state-sub" text="Servicio mohist en Monica" />
            </VBox>
        </HBox>

        <!-- Acciones rápidas -->
        <HBox spacing="10.0" styleClass="quick-actions">
            <Button fx:id="startBtn" onAction="#onStart" styleClass="success" text="Iniciar">
            <graphic>
               <ImageView fitHeight="18.0" fitWidth="17.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@../resources/power.png" />
                  </image>
               </ImageView>
            </graphic></Button>
            <Button fx:id="stopBtn" onAction="#onStop" styleClass="danger" text="Detener">
            <graphic>
               <ImageView fitHeight="18.0" fitWidth="17.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@../resources/pause.png" />
                  </image>
               </ImageView>
            </graphic></Button>
            <Button onAction="#onRestart" styleClass="accent" text="Reiniciar">
            <graphic>
               <ImageView fitHeight="18.0" fitWidth="17.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@../resources/rotate-cw.png" />
                  </image>
               </ImageView>
            </graphic></Button>
            <Region HBox.hgrow="ALWAYS" />
            <Button onAction="#onSaveAll" text="Guardar todo">
            <graphic>
               <ImageView fitHeight="18.0" fitWidth="17.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@../resources/save.png" />
                  </image>
               </ImageView>
            </graphic></Button>
            <Button onAction="#onBroadcast" text="Mensaje">
            <graphic>
               <ImageView fitHeight="18.0" fitWidth="17.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@../resources/send-horizontal.png" />
                  </image>
               </ImageView>
            </graphic></Button>
        </HBox>
        <Label fx:id="actionStatus" styleClass="action-status" text="" />

        <!-- Métricas principales (con barra de nivel) -->
        <FlowPane fx:id="metricGrid" hgap="16.0" vgap="16.0">
            <VBox spacing="8.0" styleClass="metric-card">
                <HBox alignment="CENTER_LEFT" spacing="8.0">
               <ImageView fitHeight="18.0" fitWidth="17.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@../resources/memory-stick.png" />
                  </image>
               </ImageView>
                    <Label styleClass="stat-caption" text="RAM" />
                </HBox>
                <Label fx:id="ramLabel" minHeight="-Infinity" minWidth="-Infinity" styleClass="stat-value" text="—" />
                <ProgressBar fx:id="ramBar" maxWidth="Infinity" progress="0.0" styleClass="metric-bar" />
            </VBox>
            <VBox spacing="8.0" styleClass="metric-card">
                <HBox alignment="CENTER_LEFT" spacing="8.0">
               <ImageView fitHeight="18.0" fitWidth="17.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@../resources/cpu.png" />
                  </image>
               </ImageView>
                    <Label styleClass="stat-caption" text="CPU" />
                </HBox>
                <Label fx:id="cpuLabel" minHeight="-Infinity" minWidth="-Infinity" styleClass="stat-value" text="—" />
                <ProgressBar fx:id="cpuBar" maxWidth="Infinity" progress="0.0" styleClass="metric-bar" />
            </VBox>
            <VBox spacing="8.0" styleClass="metric-card">
                <HBox alignment="CENTER_LEFT" spacing="8.0">
               <ImageView fitHeight="18.0" fitWidth="17.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@../resources/chart-network.png" />
                  </image>
               </ImageView>
                    <Label styleClass="stat-caption" text="TPS" />
                </HBox>
                <Label fx:id="tpsLabel" minHeight="-Infinity" minWidth="-Infinity" styleClass="stat-value" text="—" />
                <ProgressBar fx:id="tpsBar" maxWidth="Infinity" progress="0.0" styleClass="metric-bar" />
            </VBox>
            <VBox spacing="8.0" styleClass="metric-card">
                <HBox alignment="CENTER_LEFT" spacing="8.0">
               <ImageView fitHeight="18.0" fitWidth="17.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@../resources/users.png" />
                  </image>
               </ImageView>
                    <Label styleClass="stat-caption" text="Jugadores" />
                </HBox>
                <Label fx:id="playersLabel" minHeight="-Infinity" minWidth="-Infinity" styleClass="stat-value" text="—" />
                <ProgressBar fx:id="playersBar" maxWidth="Infinity" progress="0.0" styleClass="metric-bar" />
            </VBox>
            <VBox spacing="8.0" styleClass="metric-card">
                <HBox alignment="CENTER_LEFT" spacing="8.0">
               <ImageView fitHeight="18.0" fitWidth="17.0" pickOnBounds="true" preserveRatio="true">
                  <image>
                     <Image url="@../resources/hard-drive.png" />
                  </image>
               </ImageView>
                    <Label styleClass="stat-caption" text="Disco" />
                </HBox>
                <Label fx:id="diskLabel" minHeight="-Infinity" minWidth="-Infinity" styleClass="stat-value" text="—" />
                <ProgressBar fx:id="diskBar" maxWidth="Infinity" progress="0.0" styleClass="metric-bar" />
            </VBox>
        </FlowPane>

        <!-- Métricas secundarias -->
        <FlowPane hgap="14.0" vgap="14.0">
            <VBox spacing="6.0" styleClass="stat-card">
                <Label styleClass="stat-caption" text="Uptime" />
                <Label fx:id="uptimeLabel" styleClass="stat-value-sm" text="—" />
            </VBox>
            <VBox spacing="6.0" styleClass="stat-card">
                <Label styleClass="stat-caption" text="Mundo" />
                <Label fx:id="worldLabel" styleClass="stat-value-sm" text="—" />
            </VBox>
            <VBox spacing="6.0" styleClass="stat-card">
                <Label styleClass="stat-caption" text="Mods" />
                <Label fx:id="modsLabel" styleClass="stat-value-sm" text="—" />
            </VBox>
            <VBox spacing="6.0" styleClass="stat-card">
                <Label styleClass="stat-caption" text="Plugins" />
                <Label fx:id="pluginsLabel" styleClass="stat-value-sm" text="—" />
            </VBox>
            <VBox spacing="6.0" styleClass="stat-card">
                <Label styleClass="stat-caption" text="Chunks" />
                <Label fx:id="chunksLabel" styleClass="stat-value-sm" text="—" />
            </VBox>
            <VBox spacing="6.0" styleClass="stat-card">
                <Label styleClass="stat-caption" text="Entidades" />
                <Label fx:id="entitiesLabel" styleClass="stat-value-sm" text="—" />
            </VBox>
        </FlowPane>

        <!-- Paneles secundarios -->
        <HBox spacing="16.0" styleClass="info-panels">
            <VBox spacing="10.0" styleClass="info-card" HBox.hgrow="ALWAYS">
                <Label fx:id="playersTitle" styleClass="info-title" text="Jugadores conectados" />
                <FlowPane fx:id="playerChips" hgap="8.0" vgap="8.0" />
            </VBox>
            <VBox spacing="10.0" styleClass="info-card" HBox.hgrow="ALWAYS">
                <Label styleClass="info-title" text="Información del servidor" />
                <HBox styleClass="kv-row">
                    <Label styleClass="kv-key" text="Versión" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="versionLabel" styleClass="kv-val" text="—" />
                </HBox>
                <HBox styleClass="kv-row">
                    <Label styleClass="kv-key" text="Último backup" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="backupLabel" styleClass="kv-val" text="—" />
                </HBox>
                <HBox styleClass="kv-row">
                    <Label styleClass="kv-key" text="Puerto" />
                    <Region HBox.hgrow="ALWAYS" />
                    <Label fx:id="portLabel" styleClass="kv-val" text="—" />
                </HBox>
            </VBox>
        </HBox>
    </VBox>
</ScrollPane>
