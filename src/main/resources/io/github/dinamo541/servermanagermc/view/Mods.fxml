<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx" xmlns:fx="http://javafx.com/fxml"
      fx:controller="io.github.dinamo541.servermanagermc.controller.ModsController"
      alignment="CENTER" styleClass="content">
    <VBox alignment="CENTER" maxWidth="520.0" spacing="14.0" styleClass="placeholder">
        <padding>
            <Insets bottom="36.0" left="40.0" right="40.0" top="36.0"/>
        </padding>
        <Label styleClass="placeholder-icon" text="❖"/>
        <Label styleClass="placeholder-title" text="Mods y Plugins"/>
        <Label styleClass="placeholder-badge" text="PRÓXIMAMENTE · ETAPA 5"/>
        <Label styleClass="placeholder-desc" wrapText="true"
               text="Gestión de mods Forge y plugins Bukkit: activar, desactivar, instalar y eliminar."/>
        <ProgressBar maxWidth="Infinity" progress="0.05" styleClass="dev-bar"/>
        <Label styleClass="placeholder-foot" text="5 % planificado"/>
    </VBox>
</VBox>
