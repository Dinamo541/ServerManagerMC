{
    // Reimporta el proyecto Maven automáticamente al guardar el pom.xml.
    "java.configuration.updateBuildConfiguration": "automatic",

    // Fuerza JDK 25 para el proyecto (JavaFX 25 + release 25 exigen JDK 22+).
    "java.configuration.runtimes": [
        {
            "name": "JavaSE-25",
            "path": "C:\\Program Files\\Eclipse Adoptium\\jdk-25.0.3.9-hotspot",
            "default": true
        }
    ],

    "java.compile.nullAnalysis.mode": "automatic",

    // Oculta artefactos de build del explorador.
    "files.exclude": {
        "**/target": true
    }
}
